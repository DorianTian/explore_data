# === NL2SQL Environment Variables ===

# Server
NODE_ENV=production
API_PORT=3100
LOG_LEVEL=info
CORS_ORIGIN=https://data.askdorian.com

# Database (PostgreSQL 16 + pgvector, 同 ask-dorian 共用 RDS)
DATABASE_URL=postgresql://dorian:xxx@ask-dorian-db.xxx.ap-southeast-1.rds.amazonaws.com:5432/nl2sql?ssl=true&sslmode=require

# AI — Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=                  # Optional: proxy URL

# AI — OpenAI (Embedding)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=                     # Optional: proxy URL

# Frontend
NEXT_PUBLIC_API_URL=https://data.askdorian.com
